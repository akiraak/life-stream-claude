PORT=3000

# データベース
DB_PATH=./shopping.db

# 認証
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# メール送信（Resend）
RESEND_API_KEY=re_your_api_key
EMAIL_FROM="お料理バスケット" <noreply@chobi.me>

# Google認証
GOOGLE_CLIENT_ID=your-google-client-id

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
# 省略時は gemini-3.1-flash-lite-preview
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# 管理画面（Cloudflare Access）認証
# 本番: Cloudflare Zero Trust → Access → Applications で発行された値を入れる
# CF_ACCESS_TEAM_DOMAIN: 例 `akiraak.cloudflareaccess.com`（プロトコルなし）
# CF_ACCESS_AUD: アプリケーション固有の AUD タグ（Application overview の AUD）
CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
CF_ACCESS_AUD=your-cf-access-application-aud-tag

# ローカル開発で /admin を Cloudflare Access 抜きで触りたいときだけ有効化する。
# NODE_ENV が 'development' または 'test' のときだけ効く（'production'/'staging'/未設定では無視）。
# 1 にすると Cf-Access-Jwt-Assertion ヘッダ無しでも req.adminEmail が埋まる。
ADMIN_AUTH_DEV_BYPASS=0
ADMIN_AUTH_DEV_EMAIL=dev-admin@local

# AI 利用制限（未ログインは端末 ID ごと、ログイン済はユーザー ID ごと、JST 日次）
DEVICE_ID_SECRET=change-me-to-a-random-string-at-least-32-chars
AI_LIMIT_USER=20
AI_LIMIT_GUEST=3

# デプロイ日時（任意のフォーマット文字列。デプロイ側で更新する）
# 管理画面にはこの文字列がそのまま表示される。太平洋時間で入れる想定。
# 例: DEPLOYED_AT="2026/04/24 12:34 PDT"
# DEPLOYED_AT=

# ロギング（pino）
# LOG_LEVEL: trace / debug / info / warn / error / fatal（省略時 info）
LOG_LEVEL=info
# LOG_FILE_PATH を設定すると stdout に加えて日次ローテのファイルにも書く。
# 未設定だと stdout のみ → `/admin/` のログタブは空になる。
# 本番 Docker では docker-compose.yml で /app/data/logs/server.log を指定済み。
# 相対パスは `server/` が CWD になるので、Docker と同じ <repo>/data/logs/ に
# 落としたい場合は `../data/logs/server.log` を指す。
# LOG_FILE_PATH=../data/logs/server.log
