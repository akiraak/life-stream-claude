{
  "expo": {
    "name": "お料理バスケット",
    "slug": "cooking-basket",
    "scheme": "cooking-basket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1c1c1c"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0ce74461-e119-48fa-b214-f8762159f3bb"
    },
    "ios": {
      "bundleIdentifier": "me.chobi.basket",
      "supportsTablet": false,
      "userInterfaceStyle": "automatic",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "me.chobi.basket",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1c1c1c"
      },
      "edgeToEdgeEnabled": true,
      "userInterfaceStyle": "automatic",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ce74461-e119-48fa-b214-f8762159f3bb"
      }
    },
    "owner": "akiraak"
  }
}
